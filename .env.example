# ============================================================================
# Bitget Signal Bot — Template Environment Variables
# ============================================================================
# Salin file ini ke .env lalu isi semua value di bawah:
#   cp .env.example .env
#
# Semua nama variable di sini harus PERSIS sama dengan yang dibaca di
# config/settings.py — jangan diubah namanya.
# ============================================================================

# ── Telegram: Akun Pribadi (Telethon — listener baca sinyal) ───────────────
# Didapat dari https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+628xxxxxxxxxx

# ── Telegram: Control Bot (@BotFather) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Chat ID kamu sendiri (bukan grup sinyal) — dapatkan lewat /start ke bot
# lalu cek https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CONTROL_CHAT_ID=

# ── Bitget API ───────────────────────────────────────────────────────────────
# WAJIB pakai API key dari Bitget Demo/Paper Trading dulu (bukan live)
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_USE_SANDBOX=true          # true = Demo/Testnet, false = akun live

# ── Signal Source (grup Telegram) ───────────────────────────────────────────
SIGNAL_GROUP_NAME=TRADING HUB | VIP CC
# ID numerik topic "[FUTURES] - Signals" di grup (WAJIB diisi, tidak boleh 0)
SIGNAL_TOPIC_ID=

# ── Risk Defaults ────────────────────────────────────────────────────────────
DEFAULT_RISK_MODE=percent        # percent | fixed_usd
DEFAULT_RISK_PERCENT=1.0
DEFAULT_MAX_LOSS_USD=5.0

# ── Bot Behavior ─────────────────────────────────────────────────────────────
DRY_RUN=true                     # true = tidak ada order real yang dikirim ke exchange
DEFAULT_CONFLICT_MODE=ask        # ask | skip | add | replace
PARSER_CONFIDENCE_THRESHOLD=95   # 0–100
CONFIRMATION_TIMEOUT_MINUTES=10

# ── Circuit Breaker ──────────────────────────────────────────────────────────
CIRCUIT_BREAKER_ERROR_THRESHOLD=3
CIRCUIT_BREAKER_WINDOW_MINUTES=5

# ── WebSocket Reconciliation ──────────────────────────────────────────────────
# Jaring pengaman REST polling di belakang stream WebSocket realtime — makin
# kecil, makin ketat batas atas delay DB vs kejadian nyata di exchange kalau
# event WebSocket sampai ter-drop. Jangan terlalu kecil (< 5s) supaya tidak
# kena rate limit Bitget.
WS_RECONCILE_INTERVAL_SECONDS=15

# ── Leverage & Safety ────────────────────────────────────────────────────────
LIQUIDATION_BUFFER_PERCENT=0.05  # 5%

# False (default, direkomendasikan) = leverage_engine boleh menurunkan
# leverage otomatis demi buffer aman liquidation-vs-SL — ini yang menjamin SL
# sempat trigger SEBELUM liquidation. Leverage tetap dipilih setinggi mungkin
# yang masih aman, bukan asal minimum. Set True hanya jika paham trade-off:
# leverage selalu max, buffer liquidation bisa jadi sangat tipis.
FORCE_MAX_LEVERAGE=false

# Jarak minimum SL ke entry (persen harga) yang masih dianggap valid. Sinyal
# dengan SL lebih sempit dari ini ditolak sebelum sampai ke leverage_engine/
# exchange (lihat risk_engine.py) — position_size akan membengkak tidak wajar
# kalau dipaksakan. 0.15% konservatif untuk BTC/ETH.
MIN_SL_DISTANCE_PERCENT=0.0015

# Deviasi maksimum entry_price (dari sinyal) terhadap harga pasar live saat
# ini yang masih dianggap wajar — menangkap salah baca/kurang digit harga
# entry (mis. "6834" padahal maksudnya "68340"). 0.15 = 15%.
MAX_ENTRY_PRICE_DEVIATION_PERCENT=0.15

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=data/bot.db

# ── Timezone ─────────────────────────────────────────────────────────────────
DISPLAY_TIMEZONE=Asia/Jakarta
